# ============================================
# KATA Framework - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!
# Note: Bun loads .env automatically - no dotenv needed
#
# Variables are validated at startup by validateEnv.ts
# Only variables for current TEST_ENV are required.
# ============================================

# ============================================
# ENVIRONMENT SELECTION
# ============================================
# Which environment to test against
# Valid: local, staging
TEST_ENV=local

# ============================================
# TEST USER CREDENTIALS (Required per environment)
# ============================================
# Only credentials for your current TEST_ENV are validated.
# The other environment's credentials can be left empty.

# --- For TEST_ENV=local ---
LOCAL_USER_EMAIL=
LOCAL_USER_PASSWORD=

# --- For TEST_ENV=staging ---
STAGING_USER_EMAIL=
STAGING_USER_PASSWORD=

# ============================================
# BROWSER CONFIGURATION (Optional)
# ============================================
# Uncomment to override defaults

# HEADLESS=true
# DEFAULT_TIMEOUT=30000

# ============================================
# TMS CONFIGURATION (Optional)
# ============================================
# TMS_PROVIDER=xray
# AUTO_SYNC=false

# --- Xray Cloud (required only if TMS_PROVIDER=xray AND AUTO_SYNC=true) ---
# XRAY_CLIENT_ID=
# XRAY_CLIENT_SECRET=
# XRAY_PROJECT_KEY=PROJECT

# --- Jira Direct (required only if TMS_PROVIDER=jira AND AUTO_SYNC=true) ---
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_USER=your-email@example.com
# JIRA_API_TOKEN=
# JIRA_TEST_STATUS_FIELD=customfield_10100

# ============================================
# REPORTING (Optional)
# ============================================
# ALLURE_RESULTS_DIR=./allure-results
# SCREENSHOT_ON_FAILURE=true
# VIDEO_ON_FAILURE=true

# ============================================
# CI/CD VARIABLES (Set automatically, NOT here)
# ============================================
# CI=true          (set by GitHub Actions)
# BUILD_ID=<id>    (set by GitHub Actions)
