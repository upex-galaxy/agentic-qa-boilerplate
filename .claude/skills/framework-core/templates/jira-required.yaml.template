# .agents/jira-required.yaml
#
# Custom fields the methodology requires to be present in your Jira workspace.
# Compare your Jira against this manifest with `bun run jira:check`.
#
# Each entry's KEY is the canonical slug — the value the methodology expects to
# resolve via {{jira.<slug>}}. Your Jira's field name must slugify to this key
# (lowercase, underscores, no emojis/accents — see `bun run jira:sync-fields`
# for the exact transform).
#
# When adding a new skill that needs a new custom field, add an entry here AND
# instruct users (via README) to create the field in their Jira.
#
# Sections:
#   required  — methodology fails without these. `bun run jira:check` exits 1
#               if any are missing or mismatched.
#   optional  — enhance the workflow but won't break it if missing. Reported as
#               INFO by `bun run jira:check`; never affects exit code.
#   unmapped  — fields the methodology references semantically but that have no
#               concrete Jira field yet. Skills mention them as literal markers
#               (e.g. `customfield_ATR`) with TODO comments. Reported as INFO.

required:
  # ---- Story / User-story fields (consumed by scripts/sync-jira-issues.ts) ----
  acceptance_criteria_gherkin:
    name: '✅ Acceptance Criteria (Gherkin)'
    type: string
    description: 'Gherkin-formatted acceptance criteria attached to user stories.'
    used_by: [sync-jira-issues]

  acceptance_test_results_atr:
    name: '🧪 Acceptance Test Results (ATR)'
    type: string
    description: |
      Stores the QA test report (ATR) on the Story (Modality B comment-mirror flow).
      Mirrored as a Jira comment for diff history. Modality A teams use a separate
      Test Execution issue.
    used_by: [sprint-testing, test-documentation]

  business_rules_specification:
    name: '🚩Business Rules Specification'
    type: string
    description: 'Business rules tied to a user story, separate from acceptance criteria.'
    used_by: [sync-jira-issues]

  scope:
    name: 'Scope ⛳'
    type: string
    description: 'In-scope / out-of-scope notes captured at story-grooming time.'
    used_by: [sync-jira-issues]

  mockup:
    name: 'Mockup 🎴'
    type: string
    description: 'Link or embed of the design mockup for the story.'
    used_by: [sync-jira-issues]

  workflow:
    name: '🧬WORKFLOW'
    type: string
    description: 'User journey / workflow narrative for the story.'
    used_by: [sync-jira-issues]

  story_points:
    name: 'Story Points'
    type: number
    description: 'Agile estimate for the story (planning poker).'
    used_by: [sync-jira-issues]

  weblink_url:
    name: 'Weblink (URL) 🌍️'
    type: string
    description: 'External reference URL attached to the story.'
    used_by: [sync-jira-issues]

  # ---- Bug / Defect fields (consumed by scripts/sync-jira-issues.ts + sprint-testing reporting) ----
  actual_result_comportamiento:
    name: '🐞 Actual Result (Comportamiento)'
    type: string
    description: 'Observed behavior captured during bug repro.'
    used_by: [sync-jira-issues, sprint-testing]

  expected_result_output:
    name: '✅ Expected Result (Output)'
    type: string
    description: 'Expected behavior per acceptance criteria, contrasted against the bug.'
    used_by: [sync-jira-issues, sprint-testing]

  error_type:
    name: 'Error Type'
    type: option
    options: [content, crash, data, functional, integration, performance, security, visual]
    description: 'Bug taxonomy by error category.'
    used_by: [sync-jira-issues, sprint-testing]

  severity:
    name: 'Severity 🚩'
    type: option
    options: [critica, mayor, menor, moderada, trivial]
    description: 'Bug severity classification (impact-based).'
    used_by: [sync-jira-issues, sprint-testing]

  test_environment:
    name: 'Test Environment 📦️'
    type: option
    options: [dev, production, qa, staging, uat]
    description: 'Environment where the bug was reproduced or where the test ran.'
    used_by: [sync-jira-issues, sprint-testing]

  root_cause:
    name: 'Root Cause🐞'
    type: option
    options:
      - code_error
      - config_env_error
      - data_error
      - environment_error
      - integration_error
      - requirement_error
      - third_party_error
      - working_as_designed_wad
    description: 'Post-mortem cause classification, set after the fix.'
    used_by: [sync-jira-issues, sprint-testing]

  workaround:
    name: '🚩 Workaround'
    type: string
    description: 'Temporary mitigation steps to unblock users until the fix ships.'
    used_by: [sync-jira-issues, sprint-testing]

  evidence:
    name: '🧫EVIDENCE'
    type: string
    description: 'Bug evidence: screenshots, traces, logs, repro recordings.'
    used_by: [sync-jira-issues, sprint-testing]

  fix:
    name: 'Fix'
    type: option
    options: [bugfix, hotfix]
    description: 'Type of fix applied (bugfix vs urgent hotfix).'
    used_by: [sync-jira-issues, sprint-testing]

  # ---- TMS Modality B fields (Jira-native, no Xray) ----
  acceptance_test_plan_atp:
    name: '🧪 Acceptance Test Plan (ATP)'
    type: string
    description: |
      Stores the QA Acceptance Test Plan body on the Story itself (Modality B
      flow). Mirrored as a Jira comment for diff history. Modality A teams (Xray)
      use a separate Test Plan issue and may not need this field.
    used_by: [sprint-testing, test-documentation]

  test_status:
    name: 'Test Status🧪'
    type: option
    options: [blocked, failed, n_r, passed]
    description: 'Per-Test issue execution status (Jira-native TMS).'
    used_by: [test-documentation]

optional:
  # Fields that enhance the workflow but won't break it if missing.
  to_be_automated_qa:
    name: 'To Be Automated (QA)🧪'
    type: option
    options: [yes, no]
    description: 'Whether the Test should be automated (ROI verdict from test-documentation).'
    used_by: [test-documentation]

# Special markers — fields the methodology expects to exist semantically but
# that haven't been mapped to a real Jira custom field yet. The check command
# treats these as informational (not errors). When a real field is configured,
# move the entry to `required:` above and update the corresponding skill files
# to use {{jira.<slug>}} instead of the literal customfield_X marker.
unmapped:
  # (No unmapped slugs at this time. See README §5.3 for the unmapped pattern
  # — declare a slug here when the methodology expects a field semantically but
  # no real Jira field exists yet, then promote it to `required:` once configured.)

# Issue types (`work_types`) plus the canonical statuses + transitions the
# methodology requires per work type. Validated by `bun run jira:check` against
# the catalog at `.agents/jira-workflows.json`. Status / transition slugs are
# agnostic — the literal Jira name lives in `jira-workflows.json`, resolved
# per workspace by `bun run jira:sync-workflows` (interactive on first run,
# idempotent after). Status categories are not declared here — they're
# discovered by the sync.
#
# TODO: review each `jira_issue_type:` and adjust if your Jira uses different
# literal names (e.g. "User Story" vs "Story", "Defect" vs "Bug", "Test Case"
# vs "Test"). The canonical SLUGS (story / bug / test_case) stay the same.
# Likewise review the `required_statuses:` and `required_transitions:` and
# remove / add slugs to match what your methodology actually requires.
work_types:
  story:
    jira_issue_type: "Story"  # TODO: literal issue type name in your Jira (default: "Story")
    description: "User story / feature work item"
    required_statuses:
      backlog:                { description: "Initial state for a freshly created story" }
      ready_for_dev:          { description: "Estimated and ready to be picked up by a developer" }
      in_progress:            { description: "Developer actively working" }
      in_review:              { description: "Pull request open / code review" }
      ready_for_qa:           { description: "Deployed and ready for QA to test" }
      in_test:                { description: "QA actively testing" }
      qa_approved:            { description: "QA passed; story is verified (terminal QA verdict)" }
      deployed_to_production: { description: "Released to production (terminal success state)" }
    required_transitions:
      start_working:  { from: ready_for_dev, to: in_progress, description: "Developer picks up the story" }
      pull_request:   { from: in_progress,   to: in_review,   description: "PR opened" }
      pushed:         { from: in_progress,   to: ready_for_qa, description: "Skip review, push directly to QA" }
      deployed:       { from: in_review,     to: ready_for_qa, description: "PR merged & deployed to QA env" }
      start_testing:  { from: ready_for_qa,  to: in_test,     description: "QA begins testing" }
      qa_sign_off:    { from: in_test,       to: qa_approved, description: "QA approves the story (the canonical 'Tested' transition)" }
    used_by: [acli, sprint-testing, test-documentation, project-discovery]

  bug:
    jira_issue_type: "Bug"  # TODO: literal issue type name in your Jira (default: "Bug")
    description: "Defect / bug work item"
    required_statuses:
      open:         { description: "Newly reported bug awaiting triage" }
      in_progress:  { description: "Developer actively fixing" }
      in_review:    { description: "Pull request open" }
      ready_for_qa: { description: "Fix deployed; bug ready to retest" }
      closed:       { description: "Bug verified fixed (canonical 'verified' terminal)" }
    required_transitions:
      start_fixing:       { from: open,         to: in_progress,  description: "Developer starts working on the bug" }
      pull_request:       { from: in_progress,  to: in_review,    description: "PR opened" }
      hard_pushed:        { from: in_progress,  to: ready_for_qa, description: "Skip review, push directly to QA" }
      fixed_and_deployed: { from: in_review,    to: ready_for_qa, description: "PR merged & deployed; bug ready to retest" }
      retest_passed:      { from: ready_for_qa, to: closed,       description: "QA verifies the fix (the canonical 'Tested / VERIFIED' transition for bugs)" }
      re_open:            { from: any,          to: open,         description: "Re-open a closed bug (global transition — accepts any source state)" }
    used_by: [acli, sprint-testing]

  test_case:
    jira_issue_type: "Test"  # TODO: literal issue type name in your Jira (default: "Test")
    description: "Test case (TC) work item"
    required_statuses:
      draft:         { description: "Just created, not yet designed" }
      in_design:     { description: "Test scenario being authored" }
      ready:         { description: "Designed and ready to run / consider for automation" }
      in_review:     { description: "Under automation review" }
      candidate:     { description: "Approved as automation candidate" }
      in_automation: { description: "Being automated" }
      automated:     { description: "Merged automated test (terminal success)" }
      manual:        { description: "Terminal manual-only verdict" }
    required_transitions:
      start_design:         { from: draft,         to: in_design,     description: "Begin designing the TC" }
      ready_to_run:         { from: in_design,     to: ready,         description: "TC designed and ready" }
      approve_to_automate:  { from: in_review,     to: candidate,     description: "Reviewer approves automation" }
      start_automation:     { from: candidate,     to: in_automation, description: "Engineer starts automating" }
      automated_from_manual: { from: manual,        to: automated,     description: "Manual TC eventually automated" }
    used_by: [test-documentation, test-automation]
