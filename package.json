{
  "name": "agentic-qa-boilerplate",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic QA boilerplate built on Playwright + KATA + TypeScript. Skills-based AI workflows for the full QA lifecycle — planning, manual testing, TMS docs, automation, and regression. Portable across Claude Code, Codex, Cursor, Copilot, and OpenCode.",
  "author": "UPEX Galaxy",
  "license": "MIT",
  "homepage": "https://github.com/upex-galaxy/agentic-qa-boilerplate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/upex-galaxy/agentic-qa-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/upex-galaxy/agentic-qa-boilerplate/issues"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "integration",
    "kata",
    "automation",
    "bun",
    "typescript",
    "boilerplate",
    "ai-driven",
    "agent-skills",
    "agentskills",
    "claude-code",
    "quality-engineering",
    "shift-left-testing",
    "agentic"
  ],
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:retries": "playwright test --retries=2",
    "test:last-failed": "playwright test --last-failed",
    "test:e2e": "playwright test --project=e2e",
    "test:smoke": "playwright test --project=smoke",
    "test:integration": "playwright test --project=integration",
    "test:report": "playwright show-report",
    "test:allure": "allure generate ./allure-results -o ./allure-report --clean && allure open ./allure-report",
    "test:allure:generate": "allure generate ./allure-results -o ./allure-report --clean",
    "test:allure:open": "allure open ./allure-report",
    "test:sync": "bun run tests/utils/jiraSync.ts",
    "clean": "rm -rf test-results playwright-report allure-results allure-report reports",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:agents": "bun run scripts/agents-lint.ts",
    "agents:setup": "bun run scripts/agents-setup.ts",
    "onboarding": "bun run scripts/onboarding.ts",
    "jira:sync-fields": "bun run scripts/sync-jira-fields.ts",
    "jira:sync-workflows": "bun run scripts/sync-jira-workflows.ts",
    "jira:check": "bun run scripts/check-jira-setup.ts",
    "format": "prettier --write '**/*.{json,yml,yaml,css,scss,html}' --ignore-path .prettierignore",
    "format:check": "prettier --check '**/*.{json,yml,yaml,css,scss,html}' --ignore-path .prettierignore",
    "type-check": "tsc --noEmit",
    "env:validate": "bun run config/validateEnv.ts",
    "api:login": "bun run cli/api-login.ts",
    "api:login:local": "bun run cli/api-login.ts local",
    "api:login:staging": "bun run cli/api-login.ts staging",
    "api:sync": "bun run cli/sync-openapi.ts",
    "api:types": "bunx openapi-typescript api/openapi.json -o api/openapi-types.ts",
    "kata:manifest": "bun run scripts/kata-manifest.ts",
    "kata:manifest:watch": "bun run scripts/kata-manifest.ts --watch",
    "update": "bun run cli/update-boilerplate.ts",
    "xray": "bun run cli/xray/index.ts",
    "pw:install": "playwright install --with-deps chromium",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.16.0",
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.7",
    "@types/node": "^24.10.1",
    "allure-playwright": "^3.2.1",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.7.4",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,yml,yaml,css,scss,html}": [
      "prettier --write --ignore-path .prettierignore"
    ]
  }
}
